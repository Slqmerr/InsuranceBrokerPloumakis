# Form backend (app/api/quote/route.ts) — email delivery via https://resend.com
# Copy to .env.local for local development; set the same vars on Vercel for production.
# Without these, dev logs submissions to the console; production returns an error.

# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives all form submissions (Dimitrios' email)
QUOTE_TO_EMAIL=

# Verified sender address (optional — defaults to onboarding@resend.dev,
# which works without domain verification but only for testing)
QUOTE_FROM_EMAIL=
